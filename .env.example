# ── LINE Messaging API ──────────────────────────────────────────────
# 從 LINE Official Account Manager > 設定 > Messaging API 取得
LINE_CHANNEL_SECRET=0b89d782d59af3183805c8165de18f0d

# 從 LINE Developers Console > 特約商店TEST > Messaging API > Channel access token 取得
LINE_CHANNEL_ACCESS_TOKEN=你的_channel_access_token_貼在這裡

# ── Google Gemini API（免費）────────────────────────────────────────
# 從 https://aistudio.google.com/apikey 取得，點複製圖示後貼在這裡
GEMINI_API_KEY=你的_AIza_開頭金鑰貼在這裡

# ── 伺服器設定 ──────────────────────────────────────────────────────
PORT=5000
